# ─── Exchange credentials ───────────────────────────────────────────────────
# Binance (BTC data & live execution)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# Bybit (alternative / fallback)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_SECRET=your_bybit_secret_here

# OANDA (XAUUSD / FX data)
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ENVIRONMENT=practice   # or "live"

# ─── Data sources ────────────────────────────────────────────────────────────
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
REUTERS_RSS_FEED=https://feeds.reuters.com/reuters/businessNews

# ─── Model / artefact storage ────────────────────────────────────────────────
MODEL_ARTIFACT_PATH=./models/artifacts
DATA_CACHE_PATH=./data/cache

# ─── Runtime config ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
BACKTEST_START=2020-01-01
BACKTEST_END=2024-12-31
HMM_N_COMPONENTS=4          # number of latent regimes
HMM_COVARIANCE_TYPE=full
ATR_PERIOD=14
KELLY_FRACTION=0.25          # fractional Kelly multiplier (conservative)
MAX_POSITION_RISK_PCT=0.02   # max 2 % NAV per trade
HEDGE_CORRELATION_WINDOW=30  # rolling days for BTC/Gold correlation
